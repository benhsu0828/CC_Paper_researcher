[Unit]
Description=paper-reader Discord 指令監聽 bot (!read 隨時讀庫存論文)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/CC_Paper_researcher
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/uv run python main.py --serve
Restart=on-failure
RestartSec=30
StandardOutput=append:%h/CC_Paper_researcher/data/logs/bot.log
StandardError=append:%h/CC_Paper_researcher/data/logs/bot.log

[Install]
WantedBy=default.target
