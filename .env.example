# 複製成 .env 後填入實際金鑰（.env 不進版控）

# Notion：整合金鑰 + 要建資料庫的母頁面 id（需把母頁面分享給該整合）
# NOTION_DATABASE_ID 留空即可，首次執行會自動建立並寫回此檔
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DATABASE_ID=

# Discord 通知（Bot token + 頻道 id）
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Semantic Scholar 搜尋（選用，可提高查詢額度）
SEMANTIC_SCHOLAR_API_KEY=
